# Mangekyou SIEM - Environment Variables

# Stack version - all services must use same version
ELASTIC_VERSION=8.13.0

# Credentials
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=mangekyou_secret

# Ports
ES_PORT=9200
KIBANA_PORT=5601
LOGSTASH_PORT=5044

# JVM heap sizes
ES_JAVA_OPTS=-Xms512m -Xmx512m
LS_JAVA_OPTS=-Xms256m -Xmx256m
